# ── Database ──────────────────────────────────────────────
DB_PASSWORD=changeme
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/sms_db
SPRING_DATASOURCE_USERNAME=sms_user
SPRING_DATASOURCE_PASSWORD=changeme

# ── Redis ─────────────────────────────────────────────────
SPRING_REDIS_HOST=localhost
SPRING_REDIS_PORT=6379

# ── RabbitMQ ──────────────────────────────────────────────
SPRING_RABBITMQ_HOST=localhost
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ── JWT ───────────────────────────────────────────────────
# Must be at least 32 characters for HS256
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_KEY_AT_LEAST_32_CHARS
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

# ── MinIO / AWS S3 ────────────────────────────────────────
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin
AWS_S3_ENDPOINT=http://localhost:9000
AWS_S3_ACCESS_KEY=minioadmin
AWS_S3_SECRET_KEY=minioadmin
AWS_S3_BUCKET=sms-documents
AWS_S3_REGION=us-east-1
AWS_S3_PRESIGN_EXPIRY_MINUTES=15

# ── Email (SendGrid) ──────────────────────────────────────
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=apikey
MAIL_PASSWORD=SG.your-api-key-here

# ── SMS (MSG91) ───────────────────────────────────────────
MSG91_AUTH_KEY=
MSG91_SENDER_ID=SCHOOL

# ── Payment Gateway (Razorpay) ────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Spring Profile ────────────────────────────────────────
SPRING_PROFILE=dev

# ── Angular Frontend ─────────────────────────────────────
ANGULAR_API_URL=http://localhost:8080/api/v1
ANGULAR_WS_URL=ws://localhost:8080/ws
